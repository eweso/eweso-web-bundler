#!/bin/bash

main() (
  _current_script_dir() (
    # Not symlink? Return script directory
    if [[ ! -L "$0" ]]; then
      dirname "$0"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
      dirname "$(greadlink -f "$0")"
    else
      dirname "$(readlink -f "$0")"
    fi
  )

  local _root_dir
  _root_dir="$(realpath "$(_current_script_dir)/..")"
  cd "${_root_dir}" || exit

  docker compose run --build --rm --workdir /opt/project node \
    npm "${@}"
)

set -o pipefail
set -o nounset
main "${@}"
unset -f main
